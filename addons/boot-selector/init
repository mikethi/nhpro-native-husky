#!/bin/sh
# boot-selector: PID-1 init for the selector prepend-initrd
# Google Pixel 8 Pro (husky / zuma SoC)
#
# This script runs as the very first process after the kernel loads the
# selector initrd.  It sources shared helpers, reads a boot target, dispatches
# to the matching handler in /boot-targets/, then either:
#
#   linux      – extracts the embedded real initrd and execs its /init
#   android    – kexecs to Android on the active slot
#   android-a  – kexecs to Android slot_a explicitly
#   android-b  – kexecs to Android slot_b explicitly
#   gsi        – kexecs to Android GSI (system_a replaced by GSI image)
#   recovery   – kexecs to Android Recovery on the active slot
#   recovery-a – kexecs to Android Recovery slot_a explicitly
#   recovery-b – kexecs to Android Recovery slot_b explicitly
#   menu       – shows interactive ASCII boot menu with countdown
#   magisk-patch – Magisk patch mode (patches a stored kernel, then reboots)
#   <custom>   – any /boot-targets/<name>.sh you add is picked up automatically
#
# Boot target priority (first non-empty wins):
#   1. Kernel cmdline parameter:  boot_target=<name>
#   2. Flag file on userdata:     /userdata/.boot_target  (one line, plain text)
#   3. Built-in default:          linux
#
# Hardware notes (husky):
#   Console : ttySAC0 @ 0x10870000, 115200n8  (Exynos UART0)
#   Storage : UFS 3.1 via exynos-ufs → /dev/sda  (GPT, userdata = "userdata")
#   Boot    : Android header v4, A/B scheme, no SD card

set -e

CONSOLE=/dev/console

# ── mount kernel filesystems ─────────────────────────────────────────────────
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev 2>/dev/null || {
    mount -t tmpfs tmpfs /dev
    # Minimal static device nodes for UFS + console before udev
    mknod -m 600 /dev/console  c 5 1 2>/dev/null || true
    mknod -m 666 /dev/null     c 1 3 2>/dev/null || true
    mknod -m 660 /dev/sda      b 8 0 2>/dev/null || true
    # sda1-sda30 covers the full husky GPT layout
    i=1; while [ $i -le 30 ]; do
        mknod -m 660 "/dev/sda${i}" b 8 "$i" 2>/dev/null || true
        i=$((i + 1))
    done
}
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts 2>/dev/null || true

exec 0<$CONSOLE 1>$CONSOLE 2>$CONSOLE

echo "boot-selector: starting" >$CONSOLE

# ── load shared helpers ───────────────────────────────────────────────────────
# _common.sh provides: _find_userdata, _android_inherited_params,
# _build_android_cmdline, _set_slot_suffix, _set_boot_mode,
# _kexec_boot, _fallback_linux
# shellcheck disable=SC1091
. /boot-targets/_common.sh

# ── read boot target ──────────────────────────────────────────────────────────
BOOT_TARGET=""

# Priority 1: kernel cmdline  (fastboot boot -c "boot_target=android-a" ...)
for arg in $(cat /proc/cmdline); do
    case "$arg" in
        boot_target=*) BOOT_TARGET="${arg#boot_target=}" ;;
    esac
done

# Priority 2: flag file on userdata  (/userdata/.boot_target)
if [ -z "$BOOT_TARGET" ]; then
    USERDATA_DEV=""
    for dev in /dev/sda* /dev/nvme0n1p* /dev/mmcblk0p*; do
        [ -b "$dev" ] || continue
        label="$(blkid -o value -s PARTLABEL "$dev" 2>/dev/null)" || continue
        if [ "$label" = "userdata" ]; then
            USERDATA_DEV="$dev"
            break
        fi
    done

    if [ -n "$USERDATA_DEV" ]; then
        mkdir -p /run/boot-selector/mnt
        mounted=""
        mount -t f2fs -o ro "$USERDATA_DEV" /run/boot-selector/mnt \
              2>/dev/null && mounted=1 || true
        [ -z "$mounted" ] && \
            mount -t ext4 -o ro "$USERDATA_DEV" /run/boot-selector/mnt \
                  2>/dev/null && mounted=1 || true
        if [ -n "$mounted" ]; then
            if [ -f /run/boot-selector/mnt/.boot_target ]; then
                BOOT_TARGET="$(tr -d '[:space:]' \
                    </run/boot-selector/mnt/.boot_target)"
                echo "boot-selector: flag file on ${USERDATA_DEV} \
→ '${BOOT_TARGET}'" >$CONSOLE
            fi
            umount /run/boot-selector/mnt 2>/dev/null || true
        fi
    fi
fi

# Priority 3: default
BOOT_TARGET="${BOOT_TARGET:-linux}"

echo "boot-selector: target = ${BOOT_TARGET}" >$CONSOLE

# ── dispatch ──────────────────────────────────────────────────────────────────
TARGET_SCRIPT="/boot-targets/${BOOT_TARGET}.sh"

if [ ! -f "$TARGET_SCRIPT" ]; then
    echo "boot-selector: unknown target '${BOOT_TARGET}' – falling back to \
linux" >$CONSOLE
    TARGET_SCRIPT="/boot-targets/linux.sh"
fi

# shellcheck disable=SC1090
. "$TARGET_SCRIPT"
run_target
